# Builds the fme binary and mounts the remote for an interactive shell.
# Build context: repo root (so it can compile ./cmd/fme).
FROM golang:1.25-bookworm

# fuse3 -> fusermount3 (used by go-fuse); util-linux -> mountpoint(1).
RUN apt-get update \
    && apt-get install -y --no-install-recommends fuse3 util-linux \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY cmd ./cmd
COPY internal ./internal
RUN go build -o /usr/local/bin/fme ./cmd/fme

COPY test/docker/mount-shell.sh /usr/local/bin/mount-shell.sh
RUN chmod +x /usr/local/bin/mount-shell.sh

ENTRYPOINT ["/usr/local/bin/mount-shell.sh"]
